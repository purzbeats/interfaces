{
  "name": "interfaces",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "interfaces": "./dist-cli/interfaces.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:cli": "tsc -p tsconfig.cli.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "npm run build:cli && node dist-cli/interfaces.js",
    "render": "npm run build:cli && electron dist-cli/electron-render.js"
  },
  "dependencies": {
    "interactjs": "^1.10.27",
    "lil-gui": "^0.20.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/electron": "^1.4.38",
    "@types/node": "^22.0.0",
    "@types/three": "^0.170.0",
    "electron": "^41.0.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-glsl": "^1.3.0",
    "vitest": "^4.0.18"
  }
}
